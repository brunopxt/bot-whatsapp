import makeWASocket, {
  useMultiFileAuthState,
  DisconnectReason,
  Browsers
} from '@whiskeysockets/baileys'
import P from 'pino'
import cron from 'node-cron'

/**
 * CONFIGURAÇÕES
 */
const PREFIX = '!'
const GROUP_JID = process.env.GROUP_JID || ''
const CITY_NAME = 'Porto'
const COUNTRY_CODE = 'PT'
const TIMEZONE = process.env.TIMEZONE || 'Europe/Lisbon'

const ADMIN_ONLY = new Set(['!ban', '!promote', '!demote'])

async function startBot() {
  const { state, saveCreds } = await useMultiFileAuthState('auth_info')

  const sock = makeWASocket({
    auth: state,
    browser: Browsers.ubuntu('Bot Grupo'),
    printQRInTerminal: true,
    logger: P({ level: 'silent' })
  })

  sock.ev.on('creds.update', saveCreds)

  sock.ev.on('connection.update', ({ connection, lastDisconnect }) => {
    if (connection === 'close') {
      const statusCode = lastDisconnect?.error?.output?.statusCode
      const shouldReconnect = statusCode !== DisconnectReason.loggedOut
      if (shouldReconnect) startBot()
    } else if (connection === 'open') {
      console.log('✅ Bot conectado')
      startSchedulers(sock)
    }
  })

  sock.ev.on('messages.upsert', async ({ messages }) => {
    try {
      const msg = messages?.[0]
      if (!msg || msg.key.fromMe) return
      if (!msg.key.remoteJid?.endsWith('@g.us')) return

      const groupJid = msg.key.remoteJid
      const senderJid = msg.key.participant || msg.participant
      const text = extractText(msg)
      if (!text?.startsWith(PREFIX)) return

      const [command] = text.trim().split(/\s+/)
      const cmd = command.toLowerCase()

      const metadata = await sock.groupMetadata(groupJid)
      const senderIsAdmin = metadata.participants.some(
        (p) => p.id === senderJid && (p.admin === 'admin' || p.admin === 'superadmin')
      )
      const botUser = sock.user?.id?.split(':')[0] + '@s.whatsapp.net'
      const botIsAdmin = metadata.participants.some(
        (p) => p.id === botUser && (p.admin === 'admin' || p.admin === 'superadmin')
      )

      if (ADMIN_ONLY.has(cmd) && !senderIsAdmin) {
        await reply(sock, groupJid, msg, '⛔ Só admins podem usar isso.')
        return
      }

      switch (cmd) {
        case '!ping':
          await reply(sock, groupJid, msg, 'pong 🏓')
          break

        case '!menu':
          await reply(sock, groupJid, msg,
            '📋 Comandos:\n!ping\n!menu\n!meteo\n!ban @\n!promote @\n!demote @'
          )
          break

        case '!meteo': {
          const weather = await buildWeatherMessage()
          await reply(sock, groupJid, msg, weather)
          break
        }

        case '!ban': {
          if (!botIsAdmin) return reply(sock, groupJid, msg, 'Preciso ser admin')
          const mentioned = getMentionedUsers(msg)
          if (!mentioned.length) return reply(sock, groupJid, msg, 'Marca alguém')
          await sock.groupParticipantsUpdate(groupJid, mentioned, 'remove')
          break
        }

        case '!promote': {
          if (!botIsAdmin) return reply(sock, groupJid, msg, 'Preciso ser admin')
          const mentioned = getMentionedUsers(msg)
          if (!mentioned.length) return reply(sock, groupJid, msg, 'Marca alguém')
          await sock.groupParticipantsUpdate(groupJid, mentioned, 'promote')
          break
        }

        case '!demote': {
          if (!botIsAdmin) return reply(sock, groupJid, msg, 'Preciso ser admin')
          const mentioned = getMentionedUsers(msg)
          if (!mentioned.length) return reply(sock, groupJid, msg, 'Marca alguém')
          await sock.groupParticipantsUpdate(groupJid, mentioned, 'demote')
          break
        }
      }
    } catch (e) {
      console.error(e)
    }
  })
}

let started = false
function startSchedulers(sock) {
  if (started) return
  started = true

  if (!GROUP_JID) {
    console.log('Define GROUP_JID para envio automático')
    return
  }

  // Meteorologia diária 08:00
  cron.schedule('0 8 * * *', async () => {
    const msg = await buildWeatherMessage()
    await sock.sendMessage(GROUP_JID, { text: msg })
  }, { timezone: TIMEZONE })
}

async function buildWeatherMessage() {
  const coords = await resolveCoordinates()

  const url = `https://api.open-meteo.com/v1/forecast?latitude=${coords.lat}&longitude=${coords.lon}&current=temperature_2m,weather_code&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max&forecast_days=4&timezone=${TIMEZONE}`

  const res = await fetch(url)
  const data = await res.json()

  const c = data.current
  const d = data.daily

  const hojeEmoji = weatherCodeToEmoji(c.weather_code)
  const hojeTexto = weatherCodeToText(c.weather_code)

  const linhas = [
    `☀️ *Bom dia, grupo!*`,
    ``,
    `${hojeEmoji} *Meteorologia para Porto*`,
    `Agora: ${Math.round(c.temperature_2m)}°C — ${hojeTexto}`,
    `Hoje: máx ${Math.round(d.temperature_2m_max[0])}°C / mín ${Math.round(d.temperature_2m_min[0])}°C`,
    `Probabilidade de chuva: ${Math.round(d.precipitation_probability_max[0] ?? 0)}%`,
    ``,
    `📅 *Próximos dias*`
  ]

  for (let i = 0; i < d.time.length; i++) {
    const dataFmt = formatDatePt(d.time[i])
    const emoji = weatherCodeToEmoji(d.weather_code[i])
    const texto = weatherCodeToText(d.weather_code[i])
    linhas.push(
      `${emoji} ${dataFmt}: ${texto} | ${Math.round(d.temperature_2m_max[i])}°/${Math.round(d.temperature_2m_min[i])}° | chuva ${Math.round(d.precipitation_probability_max[i] ?? 0)}%`
    )
  }

  return linhas.join('
')
}

async function resolveCoordinates() {
  const url = `https://nominatim.openstreetmap.org/search?q=${CITY_NAME},${COUNTRY_CODE}&format=json&limit=1`
  const res = await fetch(url)
  const data = await res.json()

  return {
    lat: data[0].lat,
    lon: data[0].lon
  }
}

function extractText(msg) {
  return msg.message?.conversation || msg.message?.extendedTextMessage?.text || ''
}

function getMentionedUsers(msg) {
  return msg.message?.extendedTextMessage?.contextInfo?.mentionedJid || []
}

function weatherCodeToText(code) {
  const map = {
    0: 'Céu limpo',
    1: 'Poucas nuvens',
    2: 'Parcialmente nublado',
    3: 'Muito nublado',
    45: 'Nevoeiro',
    48: 'Nevoeiro com geada',
    51: 'Chuvisco fraco',
    53: 'Chuvisco moderado',
    55: 'Chuvisco intenso',
    61: 'Chuva fraca',
    63: 'Chuva moderada',
    65: 'Chuva forte',
    71: 'Neve fraca',
    73: 'Neve moderada',
    75: 'Neve forte',
    80: 'Aguaceiros fracos',
    81: 'Aguaceiros moderados',
    82: 'Aguaceiros fortes',
    95: 'Trovoada',
    96: 'Trovoada com granizo',
    99: 'Trovoada forte'
  }
  return map[code] || 'Outro'
}

function weatherCodeToEmoji(code) {
  if (code === 0) return '☀️'
  if (code === 1) return '🌤️'
  if (code === 2) return '⛅'
  if (code === 3) return '☁️'
  if (code === 45 || code === 48) return '🌫️'
  if ([51, 53, 55].includes(code)) return '🌦️'
  if ([61, 63, 65, 80, 81, 82].includes(code)) return '🌧️'
  if ([71, 73, 75].includes(code)) return '❄️'
  if ([95, 96, 99].includes(code)) return '⛈️'
  return '🌡️'
}

function formatDatePt(dateStr) {
  return new Date(`${dateStr}T12:00:00`).toLocaleDateString('pt-PT', {
    weekday: 'short',
    day: '2-digit',
    month: '2-digit'
  })
}

async function reply(sock, jid, msg, text) {
  await sock.sendMessage(jid, { text }, { quoted: msg })
}

startBot()
